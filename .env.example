# Copy to .env for local dev (gitignored). In production these live in the launchd plist.
HUE_AUTH_TOKEN=generate-with-openssl-rand-hex-32
# Optional: pin the bridge instead of pairing via `huemcp-cli pair` (which writes state.json):
# HUE_BRIDGE_IP=192.0.2.5
# HUE_APP_KEY=your-bridge-application-key
# HUE_PORT=8910
# HUE_LOG_LEVEL=info
